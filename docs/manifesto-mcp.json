          }
        },
        {
          "name": "cancel_interview",
          "description": "Cancela uma entrevista agendada. Motivo obrigatório. Sempre confirmar com o recrutador antes de cancelar.",
          "inputSchema": {
            "type": "object",
            "properties": {
