              "scheduled_datetime": { "type": "string", "description": "ISO 8601" },
              "interviewer_id":     { "type": "string" },
              "status":             { "type": "string", "enum": ["success", "error"] },
              "message":            { "type": "string" }
            },
            "required": ["interview_id", "candidate_id", "process_id", "scheduled_datetime", "interviewer_id", "status", "message"]
          }
        },
        {
