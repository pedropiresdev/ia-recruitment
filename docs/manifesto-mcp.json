            "type": "object",
            "properties": {
              "interview_id": { "type": "string" },
              "new_datetime": { "type": "string", "description": "ISO 8601: YYYY-MM-DDTHH:MM" },
              "reason":       { "type": "string", "description": "Motivo da remarcação" }
            },
            "required": ["interview_id", "new_datetime", "reason"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "interview_id":      { "type": "string" },
              "previous_datetime": { "type": "string" },
              "new_datetime":      { "type": "string" },
              "status":            { "type": "string", "enum": ["success", "error"] },
              "message":           { "type": "string" }
            },
            "required": ["interview_id", "previous_datetime", "new_datetime", "status", "message"]
          }
        },
        {
          "name": "get_available_slots",
          "description": "Retorna horários disponíveis de um entrevistador. Sempre consultar antes de agendar ou remarcar.",
