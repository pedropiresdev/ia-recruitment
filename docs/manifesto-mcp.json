{
  "agent": {
    "name": "recruitment-agent",
    "version": "1.0.0",
    "description": "Agente de recrutamento da LG. Gerencia abertura de vagas, triagem de candidatos, processos seletivos e agendamento de entrevistas.",
    "base_url": "https://seu-agente.exemplo.com",
    "transport": "streamable-http",
    "contact": "recrutamento@lggo.com.br"
  },

  "$defs": {
    "ProcessStatus": {
      "type": "string",
      "enum": ["em_aberto", "em_andamento", "suspenso", "encerrado"],
      "description": "Status de um processo seletivo"
    },
    "SLAStatus": {
      "type": "string",
      "enum": ["no_prazo", "em_risco", "em_atraso"],
      "description": "Status do SLA de um processo seletivo"
    },
    "CandidateStage": {
      "type": "string",
      "enum": ["inscrito", "triagem", "entrevista", "tecnico", "proposta", "contratado", "reprovado", "desistiu"],
      "description": "Etapa do candidato no processo seletivo"
    },
    "QuickAction": {
      "type": "object",
      "description": "Ação rápida recomendada com prompt pré-definido",
      "properties": {
        "label":  { "type": "string", "description": "Rótulo do botão de ação rápida" },
        "prompt": { "type": "string", "description": "Prompt enviado ao agente ao acionar a ação" }
      },
      "required": ["label", "prompt"]
    },
    "ProcessSummary": {
      "type": "object",
      "description": "Resumo de um processo seletivo",
      "properties": {
        "process_id":             { "type": "string" },
        "job_title":              { "type": "string" },
        "department":             { "type": "string" },
        "recruiter_name":         { "type": "string" },
        "status":                 { "$ref": "#/$defs/ProcessStatus" },
        "sla_status":             { "$ref": "#/$defs/SLAStatus" },
        "sla_deadline_date":      { "type": "string", "description": "Data limite no formato YYYY-MM-DD" },
        "days_since_last_update": { "type": "integer" },
        "open_candidates_count":  { "type": "integer" }
      },
      "required": ["process_id", "job_title", "department", "recruiter_name", "status", "sla_status", "sla_deadline_date", "days_since_last_update", "open_candidates_count"]
    },
    "TimelineEvent": {
      "type": "object",
      "description": "Evento no histórico cronológico de um processo",
      "properties": {
        "stage": { "type": "string" },
        "date":  { "type": "string", "description": "Data no formato YYYY-MM-DD" },
        "actor": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["stage", "date", "actor"]
    },
    "CandidateSummary": {
      "type": "object",
      "properties": {
        "candidate_id":  { "type": "string" },
        "full_name":     { "type": "string" },
        "current_stage": { "type": "string" },
        "days_in_stage": { "type": "integer" }
      },
      "required": ["candidate_id", "full_name", "current_stage", "days_in_stage"]
    },
    "CandidatesByStage": {
      "type": "object",
      "properties": {
        "stage_name": { "type": "string" },
        "candidates": { "type": "array", "items": { "$ref": "#/$defs/CandidateSummary" } }
      },
      "required": ["stage_name", "candidates"]
    },
    "CandidateProfile": {
      "type": "object",
      "properties": {
        "candidate_id":  { "type": "string" },
        "full_name":     { "type": "string" },
        "email":         { "type": "string" },
        "phone":         { "type": "string" },
        "current_stage": { "$ref": "#/$defs/CandidateStage" },
        "process_id":    { "type": "string" },
        "days_in_stage": { "type": "integer" },
        "applied_at":    { "type": "string", "description": "Data de inscrição no formato YYYY-MM-DD" }
      },
      "required": ["candidate_id", "full_name", "email", "current_stage", "process_id", "days_in_stage", "applied_at"]
    },
    "TimeSlot": {
      "type": "object",
      "properties": {
        "start_datetime": { "type": "string", "description": "Início do horário disponível (ISO 8601)" },
        "end_datetime":   { "type": "string", "description": "Fim do horário disponível (ISO 8601)" }
      },
      "required": ["start_datetime", "end_datetime"]
    },
    "InterviewDetail": {
      "type": "object",
      "properties": {
        "interview_id":        { "type": "string" },
        "candidate_id":        { "type": "string" },
        "candidate_name":      { "type": "string" },
        "process_id":          { "type": "string" },
        "interviewer_id":      { "type": "string" },
        "interview_type":      { "type": "string" },
        "scheduled_datetime":  { "type": "string", "description": "ISO 8601" },
        "duration_minutes":    { "type": "integer" },
        "status":              { "type": "string", "enum": ["agendada", "cancelada", "realizada"] },
        "notes":               { "type": "string" },
        "cancellation_reason": { "type": "string" },
        "reschedule_reason":   { "type": "string" }
      },
      "required": ["interview_id", "candidate_id", "candidate_name", "process_id", "interviewer_id", "interview_type", "scheduled_datetime", "duration_minutes", "status"]
    },
    "InterviewerInfo": {
      "type": "object",
      "properties": {
        "interviewer_id": { "type": "string" },
        "name":           { "type": "string" },
        "role":           { "type": "string" },
        "department":     { "type": "string" }
      },
      "required": ["interviewer_id", "name", "role", "department"]
    },
    "InterviewTypeInfo": {
      "type": "object",
      "properties": {
        "interview_type": { "type": "string" },
        "label":          { "type": "string" },
        "description":    { "type": "string" }
      },
      "required": ["interview_type", "label", "description"]
    }
  },

  "servers": [
    {
      "name": "recruitment-orchestrator",
      "description": "Gateway MCP do agente de recrutamento para a LiGiaPro. Expõe uma única tool de linguagem natural que internamente orquestra os 4 MCP servers de domínio (job-opening, process-management, candidate-screening, interview-scheduling). Mantém histórico de conversa por session_id persistido no PostgreSQL.",
      "endpoint": "https://seu-agente.exemplo.com/mcp/recruitment",
      "tools": [
        {
          "name": "handle_recruitment_message",
          "description": "Processa uma mensagem em linguagem natural para o agente de recrutamento. Mantém histórico de conversa por session_id — use o identificador do usuário ou da conversa na LiGiaPro para garantir continuidade entre mensagens. A resposta pode conter texto em markdown e blocos JSON com prefixo __widget para renderização de dashboards, boards de candidatos, cards de entrevista etc.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "message":    { "type": "string", "description": "Mensagem do usuário em linguagem natural (PT-BR)" },
              "session_id": { "type": "string", "description": "Identificador único da sessão/conversa (ex: user_id da LiGiaPro). Garante continuidade do histórico entre chamadas." }
            },
            "required": ["message", "session_id"]
          },
          "outputSchema": {
            "type": "string",
            "description": "Resposta do agente em markdown, podendo incluir blocos JSON de widget no formato {\"__widget\": \"<tipo>\", ...}"
          }
        }
      ]
    },

    {
      "name": "job-opening-server",
      "description": "Gerencia abertura de posições, geração de Job Description e vínculo com o ATS.",
      "endpoint": "https://seu-agente.exemplo.com/mcp/job-opening",
      "tools": [
        {
          "name": "create_job_opening",
          "description": "Inicia o fluxo unificado de abertura de posição e criação de vaga. Use quando o agente detectar uma solicitação de contratação. Coleta dados da posição, gera a Job Description e vincula a vaga no ATS com um ID único. Nunca chamar com seniority_level ou deadline_days vazios.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "position_title":  { "type": "string",  "description": "Título da posição a ser aberta" },
              "department":      { "type": "string",  "description": "Departamento solicitante da contratação" },
              "seniority_level": { "type": "string",  "enum": ["Júnior", "Pleno", "Sênior", "Especialista", "Gestão"], "description": "Nível de senioridade" },
              "deadline_days":   { "type": "integer", "description": "Prazo em dias para preenchimento da vaga" },
              "requirements":    { "type": "string",  "description": "Requisitos técnicos e comportamentais (opcional)" },
              "salary_range":    { "type": "string",  "description": "Faixa salarial esperada, ex: 'R$8.000 - R$12.000' (opcional)" },
              "requestor_name":  { "type": "string",  "description": "Nome do gestor solicitante" }
            },
            "required": ["position_title", "department", "seniority_level", "deadline_days", "requestor_name"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "opening_id":            { "type": "string", "description": "ID único da abertura de posição" },
              "job_posting_id":        { "type": "string", "description": "ID da vaga criada no ATS" },
              "job_description_draft": { "type": "string", "description": "Rascunho da Job Description gerado automaticamente" },
              "status":                { "type": "string", "enum": ["success", "error"] },
              "message":               { "type": "string" }
            },
            "required": ["opening_id", "job_posting_id", "job_description_draft", "status", "message"]
          }
        },
        {
          "name": "collect_opening_details",
          "description": "Coleta dados faltantes de uma abertura de posição em andamento via conversa natural. Use quando create_job_opening não puder ser chamado por falta de campos obrigatórios.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "opening_id":     { "type": "string", "description": "ID da abertura de posição em andamento" },
              "missing_fields": { "type": "array",  "items": { "type": "string" }, "description": "Lista de campos que precisam ser coletados" }
            },
            "required": ["opening_id", "missing_fields"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "opening_id":       { "type": "string" },
              "collected_fields": { "type": "object", "description": "Campos coletados e seus valores" },
              "remaining_fields": { "type": "array",  "items": { "type": "string" } },
              "is_complete":      { "type": "boolean" },
              "message":          { "type": "string" }
            },
            "required": ["opening_id", "collected_fields", "remaining_fields", "is_complete", "message"]
          }
        },
        {
          "name": "generate_job_description",
          "description": "Gera o rascunho da Job Description a partir dos dados coletados. Apresentar ao recrutador para revisão antes da publicação.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "opening_id": { "type": "string", "description": "ID da abertura de posição" }
            },
            "required": ["opening_id"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "opening_id":      { "type": "string" },
              "job_description": { "type": "string", "description": "Rascunho completo da Job Description" },
              "status":          { "type": "string", "enum": ["success", "error"] },
              "message":         { "type": "string" }
            },
            "required": ["opening_id", "job_description", "status", "message"]
          }
        },
        {
          "name": "link_opening_to_posting",
          "description": "Vincula a abertura de posição à vaga no ATS com um ID único compartilhado. Sempre chamar após a criação da vaga.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "opening_id":     { "type": "string", "description": "ID da abertura de posição" },
              "job_posting_id": { "type": "string", "description": "ID da vaga no ATS" }
            },
            "required": ["opening_id", "job_posting_id"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "opening_id":     { "type": "string" },
              "job_posting_id": { "type": "string" },
              "status":         { "type": "string", "enum": ["success", "error"] },
              "message":        { "type": "string" }
            },
            "required": ["opening_id", "job_posting_id", "status", "message"]
          }
        },
        {
          "name": "send_approval_reminder",
          "description": "Envia lembrete ao gestor quando a abertura não for aprovada dentro do prazo. Acionar automaticamente ao atingir deadline_days.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "opening_id":     { "type": "string", "description": "ID da abertura sem aprovação" },
              "requestor_name": { "type": "string", "description": "Nome do gestor para envio do lembrete" }
            },
            "required": ["opening_id", "requestor_name"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "opening_id":    { "type": "string" },
              "reminder_sent": { "type": "boolean" },
              "status":        { "type": "string", "enum": ["success", "error"] },
              "message":       { "type": "string" }
            },
            "required": ["opening_id", "reminder_sent", "status", "message"]
          }
        }
      ]
    },

    {
      "name": "process-management-server",
      "description": "Monitora e gerencia processos seletivos: listagem, SLA, detalhes, timeline, candidatos por etapa e suspensão.",
      "endpoint": "https://seu-agente.exemplo.com/mcp/process-management",
      "tools": [
        {
          "name": "list_processes",
          "description": "Lista processos seletivos com filtros por status e SLA. Use para responder 'quais vagas estão abertas?' ou 'quantos processos em andamento?'",
          "inputSchema": {
            "type": "object",
            "properties": {
              "status_filter": { "$ref": "#/$defs/ProcessStatus", "description": "Filtrar por status do processo (opcional)" },
              "sla_filter":    { "$ref": "#/$defs/SLAStatus",    "description": "Filtrar por status de SLA (opcional)" },
              "recruiter_id":  { "type": "string",               "description": "Filtrar por recrutador responsável (opcional)" }
            },
            "required": []
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "processes": { "type": "array", "items": { "$ref": "#/$defs/ProcessSummary" } },
              "total":     { "type": "integer" },
              "message":   { "type": "string" }
            },
            "required": ["processes", "total", "message"]
          }
        },
        {
          "name": "get_sla_status",
          "description": "Verifica o status de SLA de um processo específico ou de todos. Retorna dias restantes (negativo se atrasado).",
          "inputSchema": {
            "type": "object",
            "properties": {
              "process_id": { "type": "string", "description": "ID do processo. Se omitido, retorna todos" }
            },
            "required": []
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "process_id":          { "type": "string" },
              "sla_status":          { "$ref": "#/$defs/SLAStatus" },
              "days_until_deadline": { "type": "integer", "description": "Negativo se já vencido" },
              "message":             { "type": "string" }
            },
            "required": ["sla_status", "days_until_deadline", "message"]
          }
        },
        {
          "name": "get_process_summary",
          "description": "Retorna resumo executivo de um processo com ações recomendadas. Use para respostas rápidas sem os detalhes completos.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "process_id": { "type": "string" }
            },
            "required": ["process_id"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "process_id":          { "type": "string" },
              "summary":             { "type": "string", "description": "Resumo executivo em texto estruturado" },
              "sla_status":          { "$ref": "#/$defs/SLAStatus" },
              "recommended_actions": { "type": "array", "items": { "$ref": "#/$defs/QuickAction" } },
              "message":             { "type": "string" }
            },
            "required": ["process_id", "summary", "sla_status", "recommended_actions", "message"]
          }
        },
        {
          "name": "get_process_detail",
          "description": "Retorna detalhes completos: candidatos, histórico, SLA e próximas ações. Chamar com get_process_timeline e get_candidates_by_stage.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "process_id": { "type": "string" }
            },
            "required": ["process_id"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "process_id":             { "type": "string" },
              "job_title":              { "type": "string" },
              "department":             { "type": "string" },
              "recruiter_name":         { "type": "string" },
              "status":                 { "$ref": "#/$defs/ProcessStatus" },
              "sla_status":             { "$ref": "#/$defs/SLAStatus" },
              "sla_deadline_date":      { "type": "string", "description": "YYYY-MM-DD" },
              "days_since_last_update": { "type": "integer" },
              "open_candidates_count":  { "type": "integer" },
              "bottleneck_description": { "type": "string" },
              "days_overdue":           { "type": "integer", "description": "0 se não está atrasado" },
              "recommended_actions":    { "type": "array", "items": { "$ref": "#/$defs/QuickAction" } },
              "message":                { "type": "string" }
            },
            "required": ["process_id", "job_title", "department", "recruiter_name", "status", "sla_status", "sla_deadline_date", "days_since_last_update", "open_candidates_count", "bottleneck_description", "days_overdue", "recommended_actions", "message"]
          }
        },
        {
          "name": "get_process_timeline",
          "description": "Retorna o histórico cronológico de etapas e datas. Chamar com get_process_detail ao detalhar processo com SLA em atraso.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "process_id": { "type": "string" }
            },
            "required": ["process_id"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "process_id":       { "type": "string" },
              "timeline":         { "type": "array", "items": { "$ref": "#/$defs/TimelineEvent" } },
              "bottleneck_stage": { "type": "string", "description": "Etapa identificada como gargalo (opcional)" },
              "message":          { "type": "string" }
            },
            "required": ["process_id", "timeline", "message"]
          }
        },
        {
          "name": "get_candidates_by_stage",
          "description": "Retorna candidatos agrupados por etapa. Chamar com get_process_detail ao detalhar um processo completo.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "process_id": { "type": "string" }
            },
            "required": ["process_id"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "process_id":       { "type": "string" },
              "stages":           { "type": "array", "items": { "$ref": "#/$defs/CandidatesByStage" } },
              "total_candidates": { "type": "integer" },
              "message":          { "type": "string" }
            },
            "required": ["process_id", "stages", "total_candidates", "message"]
          }
        },
        {
          "name": "suspend_process",
          "description": "Suspende um processo seletivo. Motivo obrigatório. Nunca chamar com suspension_reason vazio ou genérico.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "process_id":        { "type": "string" },
              "suspension_reason": { "type": "string", "description": "Motivo obrigatório — nunca pode ser vazio" }
            },
            "required": ["process_id", "suspension_reason"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "process_id":        { "type": "string" },
              "status":            { "$ref": "#/$defs/ProcessStatus" },
              "suspension_reason": { "type": "string" },
              "message":           { "type": "string" }
            },
            "required": ["process_id", "status", "suspension_reason", "message"]
          }
        },
        {
          "name": "get_overdue_sla_processes",
          "description": "Lista processos com SLA vencido ou a vencer nos próximos N dias. Use para monitoramento proativo de SLA.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "days_ahead": { "type": "integer", "default": 2, "description": "Dias à frente para incluir processos em risco" }
            },
            "required": ["days_ahead"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "overdue_processes": { "type": "array", "items": { "$ref": "#/$defs/ProcessSummary" }, "description": "Processos com SLA vencido" },
              "at_risk_processes": { "type": "array", "items": { "$ref": "#/$defs/ProcessSummary" }, "description": "Processos com SLA a vencer nos próximos dias" },
              "total_critical":    { "type": "integer" },
              "message":           { "type": "string" }
            },
            "required": ["overdue_processes", "at_risk_processes", "total_critical", "message"]
          }
        }
      ]
    },

    {
      "name": "candidate-screening-server",
      "description": "Realiza triagem de candidatos, movimentação de etapas e consulta de perfis.",
      "endpoint": "https://seu-agente.exemplo.com/mcp/candidate-screening",
      "tools": [
        {
          "name": "screen_candidate",
          "description": "Realiza triagem de um candidato com base no currículo e nos critérios da vaga. Retorna recomendação (aprovar/reprovar/pendente) e justificativa.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "candidate_id": { "type": "string", "description": "ID único do candidato" },
              "process_id":   { "type": "string", "description": "ID do processo seletivo" },
              "resume_text":  { "type": "string", "description": "Texto do currículo (opcional)" },
              "notes":        { "type": "string", "description": "Anotações do recrutador (opcional)" }
            },
            "required": ["candidate_id", "process_id"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "candidate_id":   { "type": "string" },
              "process_id":     { "type": "string" },
              "recommendation": { "type": "string", "enum": ["aprovar", "reprovar", "pendente"] },
              "justification":  { "type": "string" },
              "score":          { "type": "number", "minimum": 0, "maximum": 10, "description": "Pontuação de aderência ao perfil (0–10)" },
              "status":         { "type": "string", "enum": ["success", "error"] },
              "message":        { "type": "string" }
            },
            "required": ["candidate_id", "process_id", "recommendation", "justification", "status", "message"]
          }
        },
        {
          "name": "move_candidate_stage",
          "description": "Move um candidato para uma nova etapa. Confirmar com o recrutador antes de etapas irreversíveis como 'contratado' ou 'reprovado'.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "candidate_id": { "type": "string" },
              "process_id":   { "type": "string" },
              "target_stage": { "$ref": "#/$defs/CandidateStage" },
              "reason":       { "type": "string", "description": "Motivo da movimentação (opcional)" }
            },
            "required": ["candidate_id", "process_id", "target_stage"]
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "candidate_id":   { "type": "string" },
              "process_id":     { "type": "string" },
              "previous_stage": { "type": "string" },
              "current_stage":  { "type": "string" },
              "status":         { "type": "string", "enum": ["success", "error"] },
