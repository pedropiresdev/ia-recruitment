              "process_id":        { "type": "string" },
              "interviewer_id":    { "type": "string" },
              "proposed_datetime": { "type": "string", "description": "ISO 8601: YYYY-MM-DDTHH:MM" },
              "interview_type":    { "type": "string", "enum": ["tecnica", "cultural", "gestao", "rh"] },
